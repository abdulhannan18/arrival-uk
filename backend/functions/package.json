{
  "name": "arrival-uk-functions",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p .",
    "lint": "tsc -p . --noEmit",
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test": "npm run build && firebase emulators:exec --project arrivaluk-ci --only firestore --config ../firebase.json \"npm run test:compiled\"",
    "test:compiled": "node --test \"lib/**/*.test.js\""
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.5",
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^5.1.1",
    "twilio": "^5.5.3"
  },
  "overrides": {
    "fast-xml-parser": "5.5.8",
    "@tootallnate/once": "3.0.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/node": "^20.19.33",
    "firebase-tools": "^15.11.0",
    "typescript": "^5.6.3"
  }
}
